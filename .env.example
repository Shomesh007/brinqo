# Vercel automatically provides these environment variables
# You can set them in the Vercel dashboard under Settings > Environment Variables

# App Configuration
VITE_APP_URL=https://brinqo.com

# Analytics (Optional - Replace with your actual IDs)
# These are already in index.html as placeholders
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# VITE_GTM_ID=GTM-XXXXXXX
# VITE_FB_PIXEL_ID=123456789012345

# Note: Environment variables in Vite must be prefixed with VITE_ to be exposed to the client
# For security, never commit .env files with real values to version control
